# Cellar Pi scan station — copy to .env on the Pi and fill in.
# NEVER commit the real .env. Source values from ~/.secrets/api-keys.env on the Mac.

# Google Gemini — the only model this project calls.
# On the Mac this lives in ~/.secrets/api-keys.env; on the Pi it goes here.
GEMINI_API_KEY=

# Model id for label recognition.
CELLAR_GEMINI_MODEL=gemini-flash-latest

# Service bind. 0.0.0.0 so both LAN and Tailscale reach it.
CELLAR_HOST=0.0.0.0
CELLAR_PORT=8000

# Confidence below this routes an entry to the review queue instead of
# accepting it silently. PRD §12 open question #5: start at 0.85, tune
# against the first 100 real bottles.
CELLAR_CONFIDENCE_THRESHOLD=0.85

# Hardware pins / device paths. Set once parts are in hand.
CELLAR_BUTTON_GPIO=17
CELLAR_BUTTON_LED_GPIO=27

# Where captured JPEGs and the outbound queue live on the Pi.
CELLAR_DATA_DIR=/home/pi/cellar-data
